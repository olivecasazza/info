# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov

# Coverage directory used by tools like istanbul
coverage

# nyc test coverage
.nyc_output

# Grunt intermediate storage (https://gruntjs.com/creating-plugins#storing-task-files)
.grunt

# Bower dependency directory (https://bower.io/)
bower_components

# node-waf configuration
.lock-wscript

# Compiled binary addons (https://nodejs.org/api/addons.html)
build/Release

# Dependency directories
node_modules/
jspm_packages/

# Snowpack dependency directory (https://snowpack.dev/)
web_modules/

# TypeScript cache
*.tsbuildinfo

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
yarn-integrity

# dotenv environment variables file
.env
.env.*

# Nuxt build outputs
.output/
.nuxt/
dist/

# Nix
/result
.direnv/

# flake.lock should be committed for reproducibility

# Repo-local npm cache used by flake
.npm-cache/

# Rust / Cargo
wasm/*/target

# wasm-pack output (committed or not depending on your workflow)
# If you want to commit it, comment this out.
wasm/*/pkg
wasm/*/target
wasm/spot/training/.venv-submit
wasm/target
wasm/pkg

# Spot training artifacts: obs-norm snapshots emitted by rapier-gym training
# (canonical home: skypilot-env/spot/assets/). The WASM viewer doesn't read
# these — they're just leftovers from when rapier-gym lived in info.
wasm/spot/assets/obs_mean.npy
wasm/spot/assets/obs_std.npy

# wasm/spot is sourced from skypilot-env/spot/wasm-gym via Nix at build time.
# It is not tracked in this repo; sync-wasm populates wasm/spot/pkg at runtime.

# Prevent nested wasm build artifacts
wasm/*/wasm/
result*
dist
wasm/spot/tools/asset-gen/target
